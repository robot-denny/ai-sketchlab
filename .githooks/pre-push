#!/bin/sh
# Pre-push checks — runs dotnet build + xUnit before each push.
#
# This catches the same Gate 1 failures that CI catches, but locally
# (faster feedback) so a doomed push never reaches the Umbraco Cloud
# build pipeline.
#
# Setup (one-time, per developer):
#   git config core.hooksPath .githooks
#
# To bypass in an emergency: git push --no-verify
#
# To disable this check permanently:
#   export SKIP_PREPUSH=1   (add to ~/.zshrc or ~/.bashrc)
#   — or —
#   Set ENABLE_PREPUSH=false in .githooks.conf
#
# Runtime budget: < 30s on a warm build. If it consistently exceeds this,
# consider dropping xUnit or marking slow tests as
# [Trait("Category","Slow")] and filtering them out here.

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$REPO_ROOT" ]; then
  echo "ERROR: pre-push hook could not determine repo root (is this a git repo?)." >&2
  exit 1
fi

# Source local config if present
CONF="$REPO_ROOT/.githooks.conf"
[ -f "$CONF" ] && . "$CONF"

# Allow skipping via env var or config file
if [ "$SKIP_PREPUSH" = "1" ] || [ "$ENABLE_PREPUSH" = "false" ]; then
  echo "Pre-push checks skipped (SKIP_PREPUSH=1 or ENABLE_PREPUSH=false)."
  exit 0
fi

# Drain stdin (git pipes the refs being pushed). We don't need them — the
# build+test gate is push-scope-agnostic — but reading stdin keeps the hook
# safe when invoked manually with no input piped in.
if [ ! -t 0 ]; then
  while read -r _line; do :; done
fi

cd "$REPO_ROOT" || exit 1

echo ""
echo "Running pre-push checks (build + tests)..."
echo "  Skip in an emergency: git push --no-verify"
echo "  Disable permanently: see .githooks.conf.example"
echo ""

# Capture wall-clock seconds using `date +%s`. Sub-second precision via
# `date +%s%N` is GNU-only — macOS BSD `date` lacks it. Use seconds.
START_TOTAL=$(date +%s)

# Temp logs for build/test output. Trap ensures cleanup on every exit
# path including signal-driven exits (Ctrl-C, SIGTERM).
BUILD_LOG=$(mktemp)
TEST_LOG=$(mktemp)
trap 'rm -f "$BUILD_LOG" "$TEST_LOG"' EXIT INT TERM HUP

# NOTE: the obsolete-Razor-API lint (lint-obsolete-razor-api.sh) was retired once
# ModelsBuilder source-mode (arch-modelsbuilder-source-mode) enabled build-time
# Razor compilation. The compiler now flags every CS0618 (obsolete-API) usage in
# .cshtml during `dotnet build` below — a superset of what the lint hand-matched —
# so unguarded obsolete calls fail the build here (and in CI Gate 1) directly.

# ---- Build ----
START_BUILD=$(date +%s)
dotnet build -c Release --nologo > "$BUILD_LOG" 2>&1
BUILD_EXIT=$?
END_BUILD=$(date +%s)
BUILD_SECS=$((END_BUILD - START_BUILD))

if [ "$BUILD_EXIT" -ne 0 ]; then
  echo ""
  echo "FAIL: dotnet build failed after ${BUILD_SECS}s."
  echo ""
  echo "--- Build output (tail) ---"
  tail -40 "$BUILD_LOG"
  echo "--- End build output ---"
  echo ""
  echo "  Fix the build errors above and push again."
  echo "  To bypass: git push --no-verify"
  echo ""
  exit 1
fi

# ---- Tests ----
START_TEST=$(date +%s)
dotnet test --no-build -c Release --nologo > "$TEST_LOG" 2>&1
TEST_EXIT=$?
END_TEST=$(date +%s)
TEST_SECS=$((END_TEST - START_TEST))

if [ "$TEST_EXIT" -ne 0 ]; then
  echo ""
  echo "FAIL: dotnet test failed after ${TEST_SECS}s."
  echo ""
  # Surface failing test names. xUnit's default console reporter prints
  # lines like "  Failed UmbracoProject.Tests.SmokeTests.True_IsTrue [< 1 ms]".
  # `[[:space:]]` is POSIX-portable; `\s` would be GNU-only.
  FAILED_TESTS=$(grep -E "^[[:space:]]*(Failed|FAILED|\[FAIL\])" "$TEST_LOG")
  if [ -n "$FAILED_TESTS" ]; then
    echo "--- Failed tests ---"
    echo "$FAILED_TESTS"
    echo "--- End failed tests ---"
  else
    echo "--- Test output (tail) ---"
    tail -40 "$TEST_LOG"
    echo "--- End test output ---"
  fi
  echo ""
  echo "  Fix the failing tests above and push again."
  echo "  To bypass: git push --no-verify"
  echo ""
  exit 1
fi

END_TOTAL=$(date +%s)
TOTAL_SECS=$((END_TOTAL - START_TOTAL))

echo "Pre-push OK — build: ${BUILD_SECS}s, test: ${TEST_SECS}s, total: ${TOTAL_SECS}s"
echo ""
exit 0
