{
  "name": "umbraco-17-demo-site-e2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:unit": "tsx --test tests/image-generator/**/*.test.ts",
    "generate:images": "tsx scripts/image-generator/src/cli.ts",
    "media:sync": "tsx scripts/media-sync/src/cli.ts",
    "clean:reports": "rm -rf playwright-report test-results",
    "check:lockout": "sqlite3 -header src/UmbracoProject/umbraco/Data/Umbraco.sqlite.db 'SELECT id, userName, userNoConsole, failedLoginAttempts, lastLockoutDate FROM umbracoUser WHERE id IN (1, 2, 3);'"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "@playwright/test": "^1.56",
    "@types/node": "^25.3.3",
    "@umbraco/json-models-builders": "^2.0.42",
    "@umbraco/playwright-testhelpers": "17.1.0-beta.7",
    "dotenv": "^16.3.1",
    "tsx": "^4.21.0"
  }
}
