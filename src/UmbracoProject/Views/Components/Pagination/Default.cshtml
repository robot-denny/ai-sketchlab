@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<PaginationViewModel>

@using Clean.Core.Models.ViewModels;

@if (Model.PageCount > 1)
{
    <nav class="pager" aria-label="Pagination">
        @if (Model.PageNumber > 1)
        {
            <a href="@($"{Model.Url}?page={Model.PageNumber - 1}")">← @Umbraco.GetDictionaryValue("Paging.Previous")</a>
        }
        @if (Model.ShowFirst)
        {
            <a href="@($"{Model.Url}?page=1")">1</a>
            <span>…</span>
        }
        @for (var p = Model.PageNumberStart; p <= Model.PageNumberEnd; p++)
        {
            if (p == Model.PageNumber)
            {
                <span class="on">@p</span>
            }
            else
            {
                <a href="@($"{Model.Url}?page={p}")">@p</a>
            }
        }
        @if (Model.PageNumber < Model.PageCount)
        {
            <a href="@($"{Model.Url}?page={Model.PageNumber + 1}")">@Umbraco.GetDictionaryValue("Paging.Next") →</a>
        }
    </nav>
}
