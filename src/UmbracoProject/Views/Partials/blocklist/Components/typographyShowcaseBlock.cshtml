@inherits UmbracoViewPage<BlockListItem>
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Strings

@{
    var heading = Model.Content?.Value<string>("heading");
    var intro = Model.Content?.Value<IHtmlEncodedString>("intro");

    var spacingClasses = "";
    if (Model.Settings is ISpacingProperties spacing)
    {
        spacingClasses = Clean.Core.Helpers.SpacingHelper.GetSpacingClasses(spacing.PaddingTop, spacing.PaddingBottom, spacing.PaddingLeft, spacing.PaddingRight, spacing.MarginTop, spacing.MarginBottom, spacing.MarginLeft, spacing.MarginRight);
    }
}

<div class="styleguide-block styleguide-block--type @spacingClasses" data-block-alias="typographyShowcaseBlock">
    @if (!string.IsNullOrWhiteSpace(heading))
    {
        <h2 class="styleguide-block__heading">@heading</h2>
    }
    @if (intro != null && !string.IsNullOrWhiteSpace(intro.ToHtmlString()))
    {
        <div class="styleguide-block__intro">@intro</div>
    }

    <div class="styleguide__type">
        <h3 class="overline">Headings</h3>
        <h1>Heading 1 — display voice</h1>
        <h2>Heading 2 — section voice</h2>
        <h3>Heading 3 — subsection</h3>
        <h4>Heading 4 — supporting</h4>
        <h5>Heading 5 — accent</h5>
        <h6>Heading 6 — utility</h6>
    </div>

    <div class="styleguide__type">
        <h3 class="overline">Editor classes</h3>

        <p class="lead">
            <code>.lead</code> — the lead paragraph. Lighter weight, larger size, used to open an article or surface a key idea.
        </p>

        <p class="overline">.overline — uppercase mono label</p>

        <blockquote class="blockquote">
            <p>The future is a long quiet conversation between humans and the systems they trust.</p>
            <footer class="blockquote-footer"><code>.blockquote</code> — pulled quote with display serif</footer>
        </blockquote>

        <p class="caption"><code>.caption</code> — small italic text used for image captions and asides.</p>

        <p class="pull-quote">
            &ldquo;A pull-quote draws the eye to a single sentence; <code>.pull-quote</code> centres it and breathes around it.&rdquo;
        </p>

        <p class="pull-quote-accent">
            &ldquo;<code>.pull-quote-accent</code> left-aligns the quote behind an accent rule and constrains it to 75% of the column.&rdquo;
        </p>
    </div>
</div>
