@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IBlockReference<IPublishedElement, IPublishedElement>>
@using System.Text.RegularExpressions
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks
@using Umbraco.Cms.Core.Strings

@{
    var c = Model.Content;
    var eyebrow = c.Value<string>("eyebrow");
    var title = c.Value<string>("title");
    var body = c.Value<IHtmlEncodedString>("body");
    var iconToken = c.Value<string>("iconToken")?.Trim();
    var link = c.Value<IEnumerable<Link>>("link")?.FirstOrDefault();

    // Icon token resolution: if the editor enters a Font Awesome class slug
    // (e.g. `fa-bolt`, `fa-wand-magic-sparkles`, optionally prefixed with a
    // style like `fa-solid fa-bolt` or `fa-brands fa-github`), render the
    // Font Awesome glyph. Otherwise fall back to plain text inside a chip.
    // Font Awesome 6.5.1 is loaded site-wide via master.cshtml.
    var faClasses = (string)null;
    if (!string.IsNullOrWhiteSpace(iconToken)
        && Regex.IsMatch(iconToken, @"^(fa-(solid|regular|brands|sharp|sharp-solid|sharp-regular|sharp-light|sharp-thin|light|thin|duotone)\s+)?fa-[a-z0-9-]+$"))
    {
        faClasses = Regex.IsMatch(iconToken, @"^fa-(solid|regular|brands|sharp|light|thin|duotone)")
            ? iconToken
            : $"fa-solid {iconToken}";
    }
}

@* Deferral (MINOR a11y): when `link.Target == "_blank"` no SR "opens in new tab" hint is emitted — fix in a global Link partial, not here. *@
<article class="exp-card">
    @if (faClasses != null)
    {
        <span class="exp-card__icon exp-card__icon--fa" aria-hidden="true">
            <i class="@faClasses"></i>
        </span>
    }
    else if (!string.IsNullOrWhiteSpace(iconToken))
    {
        <span class="exp-card__icon" data-icon-token="@iconToken" aria-hidden="true">@iconToken</span>
    }
    @if (!string.IsNullOrWhiteSpace(eyebrow))
    {
        <p class="exp-card__eyebrow">@eyebrow</p>
    }
    @if (!string.IsNullOrWhiteSpace(title))
    {
        <h3 class="exp-card__title">@title</h3>
    }
    @if (body != null)
    {
        <div class="exp-card__body">@body</div>
    }
    @if (link != null && !string.IsNullOrWhiteSpace(link.Url))
    {
        <a class="exp-card__link" href="@link.Url" target="@link.Target" rel="@(link.Type == LinkType.External ? "noopener" : null)">
            @(string.IsNullOrWhiteSpace(link.Name) ? link.Url : link.Name)
        </a>
    }
</article>
