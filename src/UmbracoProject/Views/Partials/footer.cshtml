@inherits UmbracoViewPage
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using Umbraco.Cms.Core.Models

@{
    var homePage = Model.AncestorOrSelf<ContentModels.Home>();
}

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            @if (homePage.FooterLogo != null)
            {
                <img src="@homePage.FooterLogo.Url()" alt="@homePage.FooterLogo.Name" />
            }
            @if (!string.IsNullOrWhiteSpace(homePage.FooterDescription?.ToString()))
            {
                <div class="footer-description">
                    @homePage.FooterDescription
                </div>
            }
        </div>
        @if (homePage.FooterNavigation != null && homePage.FooterNavigation.Any())
        {
            <nav>
                <ul class="footer-nav">
                    @foreach (var link in homePage.FooterNavigation)
                    {
                        <li>
                            <a href="@link.Url" target="@link.Target" rel="@(link.Type == LinkType.External ? "noopener" : null)">@link.Name</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</footer>
