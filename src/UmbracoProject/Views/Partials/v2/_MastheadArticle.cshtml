@inherits UmbracoViewPage<Clean.Core.Models.ViewModels.PageHeaderViewModel>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using UmbracoProject.Helpers
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache MemoryCache

@*
    v2 hybrid — article masthead.
    Source mock: D-article.html.

    Emits the head + hero contents that live INSIDE <article>.
    The caller (article.cshtml) owns:
        <div class="back">  ← rendered above <article>
        <article>           ← wraps masthead + body
            … this partial …
            <div class="art-body">…</div>
        </article>

    MainImage is rendered as an inline <figure class="art-hero">
    below the headline rather than a full-bleed background — the
    article detail layout is text-led.
*@

@{
    string title    = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title : Model.Name;
    string subtitle = Model.HasSubtitle ? Model.Subtitle : null;
    var    date     = Model.ArticleDate;
    string author   = Model.HasAuthor ? Model.AuthorName : null;
    var    cats     = Model.Categories;

    string heroUrl = Model.HasBackgroundImage
        ? Model.BackgroundImage.GetCropUrl(1600, 900)
        : null;

    // Live content node — used to compute reading time without
    // changing the PageHeaderViewModel contract.
    var here = Umbraco.AssignedContentItem;
    string readingTime = ReadingTime.Estimate(here, MemoryCache);
}

<header class="art-head">
    @if (cats != null && cats.Any())
    {
        var categoryNames = cats
            .Select(c => c.Name)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Distinct()
            .OrderBy(n => n);
        <p class="kicker">@string.Join(" · ", categoryNames)</p>
    }

    <h1>@Html.Raw(title)</h1>

    @if (!string.IsNullOrWhiteSpace(subtitle))
    {
        <p class="dek">@subtitle</p>
    }

    <div class="byline">
        @if (!string.IsNullOrWhiteSpace(author))
        {
            <span>@Umbraco.GetDictionaryValue("Article.By") <b>@author</b></span>
            <span class="sep">·</span>
        }
        @if (date.HasValue)
        {
            <span>@date.Value.ToString("MMMM d, yyyy")</span>
        }
        @if (!string.IsNullOrWhiteSpace(readingTime))
        {
            <span class="sep">·</span>
            <span>@readingTime</span>
        }
    </div>
</header>

@if (!string.IsNullOrWhiteSpace(heroUrl))
{
    <figure class="art-hero">
        <img src="@heroUrl" alt="" loading="lazy" />
    </figure>
}
