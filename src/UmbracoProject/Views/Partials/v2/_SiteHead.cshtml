@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using Umbraco.Cms.Core.Models

@*
    v2 hybrid — compact sticky site head.
    Replacement for mainNavigation.cshtml on v2-converted templates.
    Keep mainNavigation.cshtml in place; templates opt in by including
    THIS partial instead. Rendered classes: .site-head .wordmark .site-nav.

    Source mock: every D-*.html under ui_kits/web/home/ — same head on
    all 11 mocks.

    Active-link rule: a top-nav link is "current" when the current page
    is at or below that link's content node. The publication node
    (ArticleList) is treated as ancestor for article pages too.
*@

@functions {
    static bool IsCurrent(IPublishedContent here, IPublishedContent node)
    {
        if (here == null || node == null) { return false; }
        return here.Id == node.Id || here.Path.Contains("," + node.Id + ",");
    }
}

@{
    var homePage = Umbraco.ContentAtRoot().OfType<ContentModels.Home>().FirstOrDefault();
    if (homePage == null) { return; }

    var siteName = Umbraco.GetDictionaryValue("Navigation.SiteName");
    var siteLogo = homePage.Value<MediaWithCrops>("siteLogo");

    // TODO(arch-obsolete-api-migration): migrate to IDocumentNavigationQueryService.TryGetChildrenKeys().
    // Pragma scopes the obsolete .Children call so Cloud's runtime Razor compile
    // (which honors TWAE but doesn't read csproj <NoWarn>) doesn't fail as CS0618.
#pragma warning disable CS0618
    var navChildren = homePage.Children
        .Where(x => !x.Value<bool>("hideFromTopNavigation"))
        .ToList();
#pragma warning restore CS0618
}

<header class="site-head">
    <h1 class="wordmark">
        <a href="@homePage.Url()">
            @if (siteLogo != null)
            {
                <img src="@siteLogo.Url()" alt="@siteName" class="site-logo" />
            }
            else
            {
                @Html.Raw(siteName)
            }
        </a>
    </h1>
    <nav class="site-nav" aria-label="@Umbraco.GetDictionaryValue("Navigation.MenuTitle")">
        @foreach (var child in navChildren)
        {
            <a href="@child.Url()" class="@(IsCurrent(Model, child) ? "is-current" : null)">@child.Name</a>
        }
    </nav>
</header>
