@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Documentation>

@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using UmbracoProject.Helpers
@using Markdig

@{
    Layout = "master.cshtml";
    var markdownPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();
    var showSectionNavigation = Model.Value<bool>("showSectionNavigation");
    var heading = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title : Model.Name;
    var eyebrow = Model.Parent?.Name;
}

@await Html.PartialAsync("~/Views/Partials/v2/_PageHead.cshtml", new
{
    Title = heading,
    Eyebrow = eyebrow,
    Dek = Model.Subtitle,
    Pattern = Model.PageHeadPattern()
})

<main class="content@(showSectionNavigation ? "" : " no-nav")">
    @if (showSectionNavigation)
    {
        @await Html.PartialAsync("~/Views/Partials/sectionNavigation.cshtml", Model)
    }
    <div class="c-body">
        @Html.GetBlockListHtml(Model.ContentRows)

        @if (Model.MarkdownContent != null)
        {
            <div class="markdown-content">
                @Html.Raw(Markdown.ToHtml(Model.MarkdownContent.Raw, markdownPipeline))
            </div>
        }
    </div>
</main>

@if (Model.HasValue("sectionRows"))
{
    var rows = Model.Value<Umbraco.Cms.Core.Models.Blocks.BlockListModel>("sectionRows");
    foreach (var row in rows)
    {
        @await Html.PartialAsync("~/Views/Partials/contentSectionRow.cshtml", row)
    }
}