@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Error>

@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels

@{
    Layout = "master.cshtml";

    var headline = !string.IsNullOrWhiteSpace(Model.Title)
        ? Model.Title
        : "The page <em>isn't here.</em>";

    var dek = !string.IsNullOrWhiteSpace(Model.Subtitle)
        ? Model.Subtitle
        : "Either we moved it, never wrote it, or you followed a link that pre-dates the rename.";

    var actions = new System.Collections.Generic.List<(string label, string url, bool primary)>
    {
        ("← Back to the publication", "/", true),
        ("Search essays", "/search", false)
    };
}

@section Styles {
    <link href="/assets/css/listings.css" rel="stylesheet" asp-append-version="true" />
}

@await Html.PartialAsync("~/Views/Partials/v2/_PageHead.cshtml", new
{
    Title = headline,
    Eyebrow = "404 · Not found",
    Dek = dek
})

@await Html.PartialAsync("~/Views/Partials/v2/_EmptyState.cshtml", new
{
    Headline = "Find your way back",
    Actions = actions
})