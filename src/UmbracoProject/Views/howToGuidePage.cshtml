@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.HowToGuidePage>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks

@{
    Layout = "master.cshtml";
    var heading = !string.IsNullOrWhiteSpace(Model.Title) ? Model.Title : Model.Name;
    var description = Model.Description?.ToString();
    var hasDescription = !string.IsNullOrWhiteSpace(description);
    var screenshot = Model.Screenshot;
    var rows = Model.SectionRows;
}

@section Styles {
    <link href="/assets/css/styleguide.css" rel="stylesheet" asp-append-version="true" />
}

@await Html.PartialAsync("~/Views/Partials/v2/_PageHead.cshtml", new
{
    Title = heading,
    Eyebrow = "How-to guide",
    Dek = Model.Subtitle
})

<article class="styleguide">
    @if (hasDescription)
    {
        <div class="container">
            <div class="styleguide__brand-summary">@Html.Raw(description)</div>
        </div>
    }

    @if (screenshot != null)
    {
        <div class="container">
            <figure class="styleguide__screenshot">
                <img src="@screenshot.GetCropUrl(1200, 675)" alt="@heading" loading="lazy" />
            </figure>
        </div>
    }

    @await Html.PartialAsync("~/Views/Partials/_StyleGuideSectionRows.cshtml", rows)
</article>